{
  "name": "lahiru/laravel-solidgate",
  "description": "Complete Laravel wrapper for SolidGate payment gateway API with 74+ endpoints, modern PHP 8.2+ features, and comprehensive error handling",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "laravel",
    "solidgate",
    "payment",
    "gateway",
    "api",
    "payment-processing",
    "subscriptions",
    "webhooks",
    "recurring-payments",
    "alternative-payments"
  ],
  "authors": [
    {
      "name": "Lahiru Prabodha",
      "email": "lahiru@rightmo.lk"
    }
  ],
  "homepage": "https://github.com/Lprabodha/laravel-solidgate",
  "support": {
    "issues": "https://github.com/Lprabodha/laravel-solidgate/issues",
    "source": "https://github.com/Lprabodha/laravel-solidgate"
  },
  "require": {
    "php": "^8.2",
    "illuminate/support": "^10.0|^11.0|^12.0",
    "illuminate/http": "^10.0|^11.0|^12.0",
    "illuminate/routing": "^10.0|^11.0|^12.0"
  },
  "require-dev": {
    "orchestra/testbench": "^10.9|^11.0|^12.0",
    "phpunit/phpunit": "^12.5",
    "phpstan/phpstan": "^1.10",
    "laravel/pint": "^1.13"
  },
  "autoload": {
    "psr-4": {
      "Lahiru\\LaravelSolidGate\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Lahiru\\LaravelSolidGate\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Lahiru\\LaravelSolidGate\\LaravelSolidGateServiceProvider"
      ],
      "aliases": {
        "SolidGate": "Lahiru\\LaravelSolidGate\\Facades\\SolidGate"
      }
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "config": {
    "sort-packages": true,
    "preferred-install": "dist",
    "optimize-autoloader": true
  },
  "scripts": {
    "test": "phpunit",
    "analyse": "phpstan analyse",
    "format": "pint"
  }
}
