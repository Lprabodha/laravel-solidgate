{
  "name": "lahiru/laravel-solidgate",
  "description": "Laravel SDK for SolidGate — card & APM payments, subscriptions, webhooks, and reporting with official HMAC-SHA512 signing, typed responses, and smart API defaults.",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "laravel",
    "solidgate",
    "payment",
    "gateway",
    "api",
    "payment-processing",
    "subscriptions",
    "webhooks",
    "recurring-payments",
    "alternative-payments"
  ],
  "authors": [
    {
      "name": "Lahiru Prabodha",
      "email": "lahiru@rightmo.lk"
    }
  ],
  "homepage": "https://github.com/Lprabodha/laravel-solidgate",
  "support": {
    "issues": "https://github.com/Lprabodha/laravel-solidgate/issues",
    "source": "https://github.com/Lprabodha/laravel-solidgate"
  },
  "require": {
    "php": "^8.2",
    "illuminate/support": "^10.0|^11.0|^12.0",
    "illuminate/http": "^10.0|^11.0|^12.0",
    "illuminate/routing": "^10.0|^11.0|^12.0"
  },
  "require-dev": {
    "orchestra/testbench": "^10.9|^11.0|^12.0",
    "phpunit/phpunit": "^11.5.3",
    "phpstan/phpstan": "^1.10",
    "laravel/pint": "^1.13"
  },
  "autoload": {
    "psr-4": {
      "Lahiru\\LaravelSolidGate\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Lahiru\\LaravelSolidGate\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Lahiru\\LaravelSolidGate\\LaravelSolidGateServiceProvider"
      ],
      "aliases": {
        "SolidGate": "Lahiru\\LaravelSolidGate\\Facades\\SolidGate"
      }
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "config": {
    "sort-packages": true,
    "preferred-install": "dist",
    "optimize-autoloader": true
  },
  "scripts": {
    "test": "phpunit",
    "analyse": "vendor/bin/phpstan analyse",
    "format": "vendor/bin/pint",
    "format:check": "vendor/bin/pint --test"
  }
}
